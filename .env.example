# ============================================
# ClimaVis Configuration
# ============================================

# PostgreSQL
POSTGRES_USER=climavis
POSTGRES_PASSWORD=climavis_secret
POSTGRES_DB=climavis
DATABASE_URL=postgresql://climavis:climavis_secret@localhost:5432/climavis

# Backend
BACKEND_PORT=8000
FRONTEND_PORT=5173

# OpenMeteo Sync
SYNC_ON_STARTUP=true
DAILY_SYNC_HOUR=6
BULK_THRESHOLD_DAYS=50
HISTORY_START_DATE=2020-01-01
REQUEST_DELAY_MIN=1.0
REQUEST_DELAY_MAX=3.0
